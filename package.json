{
  "name": "inkflow-studio",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "next build && electron-builder build --publish never",
    "electron:win": "next build && electron-builder build --win --publish never",
    "electron:mac": "next build && electron-builder build --mac --publish never",
    "electron:linux": "next build && electron-builder build --linux --publish never",
    "cap:add:android": "npx cap add android",
    "cap:sync": "next build && npx cap sync android",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "perfect-freehand": "^1.2.2",
    "zustand": "^4.5.2",
    "immer": "^10.1.1",
    "dexie": "^3.2.7",
    "dexie-react-hooks": "^1.1.7",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "@tiptap/extension-color": "^2.4.0",
    "@tiptap/extension-text-style": "^2.4.0",
    "@tiptap/extension-highlight": "^2.4.0",
    "@tiptap/extension-underline": "^2.4.0",
    "@tiptap/extension-text-align": "^2.4.0",
    "@tiptap/extension-task-list": "^2.4.0",
    "@tiptap/extension-task-item": "^2.4.0",
    "jspdf": "^2.5.1",
    "html2canvas": "^1.4.1",
    "docx": "^8.5.0",
    "tesseract.js": "^5.1.0",
    "next-auth": "^4.24.7",
    "@supabase/supabase-js": "^2.43.4",
    "mathjs": "^13.0.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0",
    "lucide-react": "^0.383.0",
    "framer-motion": "^11.2.10",
    "react-hotkeys-hook": "^4.5.0",
    "nanoid": "^5.0.7",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3",
    "@capacitor/core": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0"
  },
  "build": {
    "appId": "studio.inkflow.app",
    "productName": "InkFlow Studio",
    "directories": { "output": "dist-electron", "buildResources": "build-resources" },
    "files": ["out/**/*", "electron/**/*", "package.json"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build-resources/icon.ico",
      "artifactName": "InkFlow-Studio-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build-resources/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build-resources/icon.png",
      "category": "Office"
    }
  }
}
