# .env.local.example
# Copy this file to .env.local and fill in your values

# ─── Google OAuth (Required for Drive sync) ───────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ─── Supabase (Optional — for Phase 3 server features) ────────────────────────
# Get from: https://supabase.com (free tier, no credit card)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Optional Paid APIs (disabled by default — app works without these) ───────

# Azure Ink Recognizer (better shape recognition, ~$1/1000 calls)
# Leave empty to use free offline $1 Unistroke Recognizer instead
NEXT_PUBLIC_AZURE_INK_KEY=

# Google Vision OCR (better accuracy, ~$1.50/1000 images)
# Leave empty to use free Tesseract.js instead
NEXT_PUBLIC_GOOGLE_VISION_KEY=

# MyScript iinkJS (real-time OCR, requires paid license ~$500/yr)
# Leave empty to use free Tesseract.js instead
NEXT_PUBLIC_MYSCRIPT_KEY=
